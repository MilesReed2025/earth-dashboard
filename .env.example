# ─────────────────────────────────────────────────────────────────────────────
# EARTH dashboard — environment / secrets
# Copy this file to .env and fill in your values. Never commit .env.
# All ${VAR} references in hearth.yaml are resolved server-side; the raw values
# never reach the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Port the dashboard listens on (default: 8787)
PORT=8787

# ── AI features (YouTube channel suggestions, weather narrative) ──────────────
# Get a free key at https://console.mistral.ai
MISTRAL_KEY=

# ── Jellyfin ──────────────────────────────────────────────────────────────────
# Jellyfin → Dashboard → API Keys → Add
JELLYFIN_URL=http://jellyfin.local:8096
JELLYFIN_KEY=

# ── Radarr ────────────────────────────────────────────────────────────────────
# Radarr → Settings → General → API Key
RADARR_URL=http://radarr.local:7878
RADARR_KEY=

# ── Sonarr ────────────────────────────────────────────────────────────────────
# Sonarr → Settings → General → API Key
SONARR_URL=http://sonarr.local:8989
SONARR_KEY=

# ── Immich ────────────────────────────────────────────────────────────────────
# Immich → Account Settings → API Keys → New API Key
IMMICH_URL=http://immich.local:2283
IMMICH_KEY=

# ── qBittorrent ───────────────────────────────────────────────────────────────
# qBittorrent → Options → Web UI → Authentication
QBITTORRENT_URL=http://qbittorrent.local:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=

# ── AdGuard Home ─────────────────────────────────────────────────────────────
# AdGuard Home → Settings → Login credentials
ADGUARD_URL=http://adguard.local:3000
ADGUARD_USER=admin
ADGUARD_PASS=

# ── Glances (system monitoring) ───────────────────────────────────────────────
# Start Glances with: glances -w  (or as a systemd service)
# Leave GLANCES_USER/PASS blank if Glances has no password set
GLANCES_URL=http://localhost:61208
GLANCES_USER=
GLANCES_PASS=

# ── Uptime Kuma ────────────────────────────────────────────────────────────────
# Settings → Status Pages → create one listing the monitors to expose, then
# set UPTIME_KUMA_KEY to its slug. The status page must be unauthenticated.
UPTIMEKUMA_URL=http://uptimekuma.local:3001
UPTIMEKUMA_KEY=

# ── SSL certificate expiry ───────────────────────────────────────────────────
# No credentials needed — reads the cert directly via a TLS handshake.
# For multiple hosts, prefer one `sslcheck` entry per host in earth.yaml;
# these vars are a single-host fallback.
SSLCHECK_HOST=example.com
SSLCHECK_PORT=443
